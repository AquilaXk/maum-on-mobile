  "criteria": {
    "screenReader": {
      "owner": "mobile-qa",
      "rule": "핵심 화면의 주요 버튼, 입력, 상태 메시지는 목적이 드러나는 semantic label을 가진다.",
      "evidenceItems": [
        {
          "id": "design-system-state-semantics",
          "file": "front/test/theme/app_design_system_test.dart",
          "patterns": ["state views expose journey semantics", "find.bySemanticsLabel", "공통 권한 상태"]
        }
      ]
    },
    "textScale": {
      "owner": "mobile-qa",
      "requiredScales": [1, 1.5, 2],
      "rule": "Android/iOS text scale 100%, 150%, 200%에서 CTA와 오류 문구가 잘리지 않는다.",
      "evidenceItems": [
        {
          "id": "quality-text-scale",
          "file": "front/test/quality/mobile_quality_gate_test.dart",
          "patterns": ["small-screen-large-text", "textScale: 1.35", "tester.takeException\\(\\), isNull"]
        },
        {
          "id": "moderation-large-text",
          "file": "front/test/features/moderation/content_moderation_feedback_panel_test.dart",
          "patterns": ["TextScaler.linear\\(1.8\\)", "콘텐츠 검수 차단 안내"]
        }
      ]
    },
    "contrast": {
      "owner": "design-system",
      "minimumNormalTextRatio": 4.5,
      "minimumLargeTextRatio": 3,
      "rule": "오류, 성공, 경고, 위험 상태 색상은 라이트/다크 모드에서 충분한 대비를 유지한다.",
      "evidenceItems": [
        {
          "id": "theme-dark-mode",
          "file": "front/test/quality/mobile_quality_gate_test.dart",
          "patterns": ["dark-mode", "buildDarkAppTheme", "AppNoticeTone.success"]
        },
        {
          "id": "state-tone-colors",
          "file": "front/lib/shared/ui/app_design_system.dart",
          "patterns": ["errorContainer", "_stateColors", "_noticeColors"]
        }
      ]
    },
    "touchTarget": {
      "owner": "design-system",
      "minimumDp": 48,
      "rule": "탭 가능한 컨트롤은 최소 48dp 터치 영역을 가진다.",
      "evidenceItems": [
        {
          "id": "theme-minimum-size",
          "file": "front/lib/theme/app_theme.dart",
          "patterns": ["minimumSize: const Size\\(48, 52\\)", "minimumSize: const Size\\(48, 48\\)"]
        },
        {
          "id": "story-touch-target",
          "file": "front/test/features/story/story_screen_test.dart",
          "patterns": ["comment action controls keep mobile touch targets", "greaterThanOrEqualTo\\(48\\)"]
        }
      ]
    },
    "keyboardAutofill": {
      "owner": "mobile-qa",
      "rule": "로그인, 가입, 비밀번호 재설정 입력은 키보드 타입, autofill, 완료 액션을 명시한다.",
      "evidenceItems": [
        {
          "id": "auth-autofill",
          "file": "front/lib/features/auth/presentation/auth_screen.dart",
          "patterns": ["AutofillHints.email", "AutofillHints.password", "TextInputAction.done"]
        }
      ]
    }
  },
