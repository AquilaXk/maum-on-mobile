{
  "version": 1,
  "platforms": ["android", "ios"],
  "tapPolicy": {
    "markReadBeforeNavigate": true,
    "dedupeByNotificationId": true,
    "restorePendingTapAfterAuthentication": true,
    "fallbackDestination": "notifications"
  },
  "permissionStates": {
    "requestable": {
      "title": "푸시 알림 권한을 확인해 주세요.",
      "actionLabel": "권한 요청"
    },
    "granted": {
      "title": "푸시 알림을 받을 수 있습니다.",
      "actionLabel": "알림 확인"
    },
    "denied": {
      "title": "푸시 알림 권한이 꺼져 있습니다.",
      "actionLabel": "설정 열기"
    },
    "error": {
      "title": "푸시 알림을 설정하지 못했습니다.",
      "actionLabel": "다시 시도"
    }
  },
  "connectionStates": {
    "connecting": {
      "label": "연결 중",
      "reconnectAction": false
    },
    "connected": {
      "label": "연결됨",
      "reconnectAction": false
    },
    "unstable": {
      "label": "연결 불안정",
      "reconnectAction": true
    },
    "disconnected": {
      "label": "연결 끊김",
      "reconnectAction": true
    }
  },
  "routes": [
    {
      "type": "new_letter",
      "destination": "letter",
      "requiredPayload": ["notificationId", "letterId"],
      "fallback": {
        "destination": "notifications",
        "message": "편지를 바로 열 수 없어 알림 목록에 머뭅니다."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "열 수 있는 새 편지가 없습니다.",
        "message": "편지가 이동되었거나 이미 처리되었을 수 있습니다."
      },
      "errorState": {
        "targetMissing": "편지를 찾을 수 없습니다.",
        "unauthorized": "편지를 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 새 편지, {destination}로 이동"
    },
    {
      "type": "letter_read",
      "destination": "letter",
      "requiredPayload": ["notificationId", "letterId"],
      "fallback": {
        "destination": "notifications",
        "message": "편지 상태를 바로 열 수 없어 알림 목록에 머뭅니다."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "확인할 편지 상태가 없습니다.",
        "message": "편지함을 새로고침한 뒤 다시 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "편지 상태를 찾을 수 없습니다.",
        "unauthorized": "편지 상태를 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 편지 읽음 상태, {destination}로 이동"
    },
    {
      "type": "writing_status",
      "destination": "letter",
      "requiredPayload": ["notificationId", "letterId"],
      "fallback": {
        "destination": "notifications",
        "message": "편지 작성 상태를 바로 열 수 없어 알림 목록에 머뭅니다."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "진행 중인 답장 상태가 없습니다.",
        "message": "편지함에서 최신 상태를 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "답장 작성 상태를 찾을 수 없습니다.",
        "unauthorized": "답장 작성 상태를 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 답장 작성 상태, {destination}로 이동"
    },
    {
      "type": "reply_arrival",
      "destination": "letter",
      "requiredPayload": ["notificationId", "letterId"],
      "fallback": {
        "destination": "notifications",
        "message": "답장을 바로 열 수 없어 알림 목록에 머뭅니다."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "열 수 있는 답장이 없습니다.",
        "message": "편지함을 새로고침한 뒤 다시 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "답장을 찾을 수 없습니다.",
        "unauthorized": "답장을 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 답장 도착, {destination}로 이동"
    },
    {
      "type": "consultation_reply",
      "destination": "consultation",
      "requiredPayload": ["notificationId"],
      "fallback": {
        "destination": "notifications",
        "message": "상담 응답을 바로 열 수 없어 알림 목록에 머뭅니다."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "확인할 상담 응답이 없습니다.",
        "message": "상담 화면에서 새 응답을 다시 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "상담 응답을 찾을 수 없습니다.",
        "unauthorized": "상담 응답을 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 상담 응답, {destination}로 이동"
    },
    {
      "type": "report_status",
      "destination": "notifications",
      "requiredPayload": ["notificationId", "reportId"],
      "fallback": {
        "destination": "notifications",
        "message": "신고 처리 상태를 알림 화면에서 확인해 주세요."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "확인할 신고 처리 상태가 없습니다.",
        "message": "신고 탭을 새로고침한 뒤 다시 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "신고 처리 상태를 찾을 수 없습니다.",
        "unauthorized": "신고 처리 상태를 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 신고 처리 상태, {destination}로 이동"
    },
    {
      "type": "fallback",
      "destination": "notifications",
      "requiredPayload": ["notificationId"],
      "fallback": {
        "destination": "notifications",
        "message": "알림 화면에서 내용을 확인해 주세요."
      },
      "tapBehavior": {
        "markReadBeforeNavigate": true,
        "dedupeByNotificationId": true
      },
      "emptyState": {
        "title": "알림 대상이 지정되지 않았습니다.",
        "message": "알림 목록에서 내용을 확인해 주세요."
      },
      "errorState": {
        "targetMissing": "알림 대상을 확인할 수 없습니다.",
        "unauthorized": "알림 대상을 확인할 권한이 없습니다."
      },
      "accessibilityLabelTemplate": "{readState} 알림, 일반 알림, {destination}로 이동"
    }
  ]
}
