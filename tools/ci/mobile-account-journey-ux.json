{
  "version": 1,
  "platforms": ["android", "ios"],
  "journeys": [
    {
      "id": "login",
      "title": "로그인",
      "primaryCta": "로그인",
      "pendingState": {
        "label": "로그인 중"
      },
      "successState": {
        "message": "홈 화면으로 이동합니다."
      },
      "failureState": {
        "message": "이메일 또는 비밀번호를 확인해 주세요.",
        "retryLabel": "다시 시도"
      },
      "accessibility": {
        "summaryLabel": "이메일과 비밀번호로 로그인"
      },
      "layout": {
        "smallScreenRule": "키보드가 열려도 제출 버튼과 오류 문구가 가려지지 않는다."
      }
    },
    {
      "id": "signup",
      "title": "회원가입",
      "primaryCta": "가입하기",
      "pendingState": {
        "label": "가입 처리 중"
      },
      "successState": {
        "message": "가입이 완료되어 홈 화면으로 이동합니다."
      },
      "failureState": {
        "message": "입력값을 확인한 뒤 다시 시도해 주세요.",
        "retryLabel": "수정하기"
      },
      "accessibility": {
        "summaryLabel": "이메일, 비밀번호, 닉네임, 필수 동의를 입력하는 가입 양식"
      },
      "layout": {
        "smallScreenRule": "필수 동의와 가입 버튼이 한 화면에서 순서대로 탐색된다."
      }
    },
    {
      "id": "password_reset_request",
      "title": "비밀번호 재설정 요청",
      "primaryCta": "재설정 안내 받기",
      "pendingState": {
        "label": "요청 전송 중"
      },
      "successState": {
        "message": "계정이 있으면 재설정 안내가 전송됩니다."
      },
      "failureState": {
        "message": "잠시 뒤 다시 시도해 주세요.",
        "retryLabel": "다시 요청"
      },
      "accessibility": {
        "summaryLabel": "가입 이메일로 비밀번호 재설정 안내 요청"
      },
      "layout": {
        "smallScreenRule": "이메일 입력 필드와 요청 버튼이 화면 하단 고정 영역에 가려지지 않는다."
      }
    },
    {
      "id": "password_reset_confirm",
      "title": "새 비밀번호 설정",
      "primaryCta": "비밀번호 변경",
      "pendingState": {
        "label": "비밀번호 변경 중"
      },
      "successState": {
        "message": "비밀번호가 변경되었습니다. 다시 로그인해 주세요."
      },
      "failureState": {
        "message": "재설정 시간이 지났거나 입력값이 올바르지 않습니다.",
        "retryLabel": "다시 입력"
      },
      "accessibility": {
        "summaryLabel": "새 비밀번호와 확인값을 입력하는 재설정 양식"
      },
      "layout": {
        "smallScreenRule": "비밀번호 조건과 오류 설명이 입력 필드 바로 아래에 표시된다."
      }
    },
    {
      "id": "account_withdrawal",
      "title": "계정 탈퇴",
      "primaryCta": "탈퇴하기",
      "pendingState": {
        "label": "탈퇴 처리 중"
      },
      "successState": {
        "message": "탈퇴가 완료되었습니다."
      },
      "failureState": {
        "message": "탈퇴를 처리하지 못했습니다. 계정 상태를 확인해 주세요.",
        "retryLabel": "다시 시도"
      },
      "accessibility": {
        "summaryLabel": "계정 탈퇴 결과와 데이터 처리 안내 확인"
      },
      "layout": {
        "smallScreenRule": "탈퇴 결과 안내, 취소 버튼, 실행 버튼이 명확한 순서로 배치된다."
      }
    }
  ],
  "inputRules": {
    "signup": {
      "fields": {
        "email": {
          "rule": "valid_email",
          "errorMessage": "올바른 이메일 주소를 입력해 주세요."
        },
        "password": {
          "rule": "minimum_8_characters",
          "errorMessage": "비밀번호는 8자 이상이어야 합니다."
        },
        "passwordConfirm": {
          "rule": "matches_password",
          "errorMessage": "비밀번호가 서로 일치하지 않습니다."
        },
        "nickname": {
          "rule": "2_to_20_characters",
          "errorMessage": "닉네임은 2자 이상 20자 이하로 입력해 주세요."
        },
        "requiredTerms": {
          "rule": "all_required_terms_checked",
          "errorMessage": "필수 동의 항목을 확인해 주세요."
        }
      }
    }
  },
  "permissionPrompts": {
    "notifications": {
      "requestTiming": "just_in_time",
      "prePromptMessage": "알림이 필요한 순간에 권한을 요청합니다.",
      "deniedRecovery": {
        "action": "open_settings",
        "message": "설정에서 알림 권한을 켤 수 있습니다."
      }
    },
    "photos": {
      "requestTiming": "just_in_time",
      "prePromptMessage": "사진을 첨부할 때 앨범 권한을 요청합니다.",
      "deniedRecovery": {
        "action": "open_settings",
        "message": "설정에서 사진 접근 권한을 변경할 수 있습니다."
      }
    },
    "camera": {
      "requestTiming": "just_in_time",
      "prePromptMessage": "사진을 촬영할 때 카메라 권한을 요청합니다.",
      "deniedRecovery": {
        "action": "open_settings",
        "message": "설정에서 카메라 권한을 켤 수 있습니다."
      }
    }
  },
  "dangerousActions": {
    "accountWithdrawal": {
      "requiresReauthentication": true,
      "confirmationText": "탈퇴하면 계정 사용이 중단됩니다.",
      "cancelLabel": "계속 사용하기",
      "destructiveLabel": "탈퇴하기"
    }
  },
  "responsiveAccessibility": {
    "smallScreen": {
      "rule": "320px 너비에서도 버튼과 오류 문구가 겹치지 않는다."
    },
    "largeText": {
      "rule": "큰 글자 설정에서 필드 설명과 오류 문구가 두 줄 이상으로 안전하게 줄바꿈된다."
    },
    "darkMode": {
      "rule": "오류, 성공, 위험 상태가 다크 모드 명암비를 유지한다."
    },
    "screenReader": {
      "rule": "입력 필드, 오류 문구, CTA, 위험 버튼에 의미 있는 라벨을 제공한다."
    }
  }
}
