# Deployment environment template. Copy to a local env file and fill secrets.
# Do not commit populated env files.

OCI_A1_SSH_HOST=
OCI_A1_SSH_PORT=22
OCI_A1_SSH_USER=ubuntu
OCI_A1_SSH_PRIVATE_KEY_B64=
OCI_A1_SSH_KNOWN_HOSTS_B64=

# Optional base64 payloads for later SSH-based deployment hooks.
OCI_A1_BACKEND_ENV_B64=
OCI_A1_VERTEX_KEY_JSON_B64=

STAGING_BASE_URL=https://maumon.example.com
STAGING_PUBLIC_API_BASE_URL=https://maumon.example.com
STAGING_SMOKE_HEALTH_PATH=/actuator/health
STAGING_SMOKE_READ_PATH=/actuator/health
STAGING_SMOKE_WRITE_PATH=/actuator/health
STAGING_SMOKE_WRITE_METHOD=GET
STAGING_SMOKE_WRITE_BODY={}
STAGING_SMOKE_AUTH_HEADER_NAME=Authorization
STAGING_SMOKE_AUTH_HEADER_VALUE=

# Release deploy readiness gate variables.
MAUMON_STAGING_SPRING_PROFILES_ACTIVE=staging,object-storage
MAUMON_STAGING_DB_URL=jdbc:postgresql://postgres:5432/maum_on_mobile
MAUMON_STAGING_DB_USERNAME=postgres
MAUMON_STAGING_DB_PASSWORD=
MAUMON_PROD_SPRING_PROFILES_ACTIVE=production,object-storage
MAUMON_PROD_DB_URL=jdbc:postgresql://postgres:5432/maum_on_mobile
MAUMON_PROD_DB_USERNAME=postgres
MAUMON_PROD_DB_PASSWORD=
MAUMON_OBJECT_STORAGE_BUCKET=
MAUMON_OBJECT_STORAGE_ENDPOINT=
MAUMON_OBJECT_STORAGE_ACCESS_KEY=
MAUMON_OBJECT_STORAGE_SECRET_KEY=
MAUMON_PUSH_FCM_PROJECT_ID=
MAUMON_PUSH_FCM_ACCESS_TOKEN=
MAUMON_PUSH_APNS_TOPIC=
MAUMON_PUSH_APNS_AUTHORIZATION_TOKEN=
MAUMON_GOOGLE_CLOUD_PROJECT_ID=grepp-ai-project
MAUMON_GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/vertex-key.json
MAUMON_AI_CONSULTATION_ENDPOINT=
MAUMON_AI_CONSULTATION_AUTHORIZATION_TOKEN=
MAUMON_AI_MODERATION_ENDPOINT=
MAUMON_AI_MODERATION_AUTHORIZATION_TOKEN=
MAUMON_APP_JWT_SECRET=
MAUMON_BACKEND_DEPLOY_VERSION=
MAUMON_ANDROID_APP_VERSION=0.1.0+1
MAUMON_IOS_APP_VERSION=0.1.0+1
MAUMON_API_CONTRACT_VERSION=mobile-api-v1

# Backend runtime variables consumed by back/src/main/resources/application.yml.
SPRING_PROFILES_ACTIVE=production,object-storage
DB_URL=jdbc:postgresql://postgres:5432/maum_on_mobile
DB_USERNAME=postgres
DB_PASSWORD=
APP_JWT_SECRET=
PUSH_FCM_PROJECT_ID=
PUSH_FCM_ACCESS_TOKEN=
PUSH_APNS_TOPIC=
PUSH_APNS_AUTHORIZATION_TOKEN=
GOOGLE_CLOUD_PROJECT_ID=grepp-ai-project
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/vertex-key.json
AI_CONSULTATION_ENDPOINT=
AI_CONSULTATION_AUTHORIZATION_TOKEN=
AI_MODERATION_ENDPOINT=
AI_MODERATION_AUTHORIZATION_TOKEN=
MAUMON_STORE_REVIEW_SEED_ENABLED=false
SPRING__MAIL__HOST=
SPRING__MAIL__PORT=587
SPRING__MAIL__USERNAME=
SPRING__MAIL__PASSWORD=
SPRING__MAIL__PROPERTIES__MAIL__SMTP__AUTH=true
SPRING__MAIL__PROPERTIES__MAIL__SMTP__STARTTLS__ENABLE=true
CUSTOM__MEMBER__SIGNUP__MAIL_ENABLED=false
CUSTOM__MEMBER__SIGNUP__MAIL_FROM=
CUSTOM__MEMBER__SIGNUP__MAIL_SUBJECT=[Maum On] 회원가입 이메일 인증

# Local key path used by compose-style deployments before mounting to /run/secrets/vertex-key.json.
VERTEX_AI_CREDENTIALS_HOST_PATH=./vertex-key.json
